    "typescript": "^5.9.0",
    "@modular-prompt/experiment": "file:../modular-prompt/packages/experiment",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/otolab/modular-prompt-pi-provider.git"
