# ~/.pi/agent/modular-prompt-provider/config.yaml
# または .pi/modular-prompt-provider/config.yaml
#
# 優先度: プロジェクト（trust 後）> グローバル > MODULAR_PROMPT_PI_MODEL > コードデフォルト
# 詳細: docs/configuration.md, docs/workflow.md

providers:
  mlx:
    pythonPath: ~/.local/share/mise/shims/python3
    cacheDir: ~/.pi/agent/modular-prompt-provider/cache

models:
  default:
    provider: mlx
    model: prism-ml/Ternary-Bonsai-1.7B-mlx-2bit
    defaultQueryOptions:
      maxTokens: 8192
      temperature: 0.7

  bonsai:
    provider: mlx
    model: prism-ml/Ternary-Bonsai-1.7B-mlx-2bit
    defaultQueryOptions:
      maxTokens: 8192

modelSets:
  default:
    chat: bonsai
    default: default

workflow:
  agentic:
    type: agentic
    modelSet: default
    virtualModel: agentic-chat

processes:
  default:
    model: bonsai
  compaction:
    model: bonsai

compact:
  strategy: stream-summarize

cache:
  maxAgeDays: 7
  maxSizeGb: 5.0
  minFreeDiskGb: 2.0
  sweepOnStartup: true
  sweepBeforeWrite: true

logging:
  level: info
  requestResponseLevel: full
  dir: ~/.pi/agent/modular-prompt-provider/logs/requests
